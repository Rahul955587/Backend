<link rel="stylesheet" href="/style.css">
<h2>Your Todos</h2>

<form method="POST" action="/todos/add">
  <input name="title" placeholder="New Todo" required />
  <button>Add</button>
</form>

<ul>
  <% todos.forEach(todo => { %>
    <li>
      <form method="POST" action="/todos/toggle/<%= todo._id %>" style="display:inline;">
        <button><%= todo.completed ? "✅" : "❌" %></button>
      </form>

      <%= todo.title %>

      <form method="POST" action="/todos/delete/<%= todo._id %>" style="display:inline;">
        <button>Delete</button>
      </form>
    </li>
  <% }) %>
</ul>

<br>
<a href="/logout">Logout</a>